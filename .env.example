# Server
PORT=3000
NODE_ENV=development

# MongoDB (e.g. Atlas connection string or local)
MONGODB_URI=mongodb://127.0.0.1:27017/hireboard

# Auth (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# Browser origin for credentialed CORS (refresh cookie)
CLIENT_ORIGIN=http://localhost:5173

# Email verification (OTP in Redis, 10 min TTL)
REDIS_URL=redis://127.0.0.1:6379

SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to true only if your host uses implicit TLS on that port
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="HireBoard <noreply@example.com>"

# Cron for due reminder emails (every 5 minutes, wall clock in this zone)
CRON_TIMEZONE=UTC
